datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                 String       @id @default(uuid())
  firstName          String?
  lastName           String?
  email              String       @unique
  password           String       // Hashed password
  role               String       @default("Read Only") // Super Admin, CTS Consultant, Read Only
  active             Boolean      @default(true)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  lastLogin          DateTime?
  mustChangePassword Boolean      @default(false)
  assessments        Assessment[]
  advisors           Advisor[]
}

model Advisor {
  id                    String       @id @default(uuid())
  name                  String
  firmName              String
  email                 String?
  phone                 String?
  currentFirm           String?
  currentCustodian      String?
  futureCustodian       String?
  businessModel         String       @default("Unknown") // RIA, Broker Dealer, Hybrid, Unknown
  protocolStatus        String       @default("Unsure")  // Yes, No, Unsure
  totalAum              Float?       // In Millions USD
  annualRevenue         Float?       // In USD
  households            Int?
  accounts              Int?
  staffCount            Int?
  crm                   String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  assessments           Assessment[]
  contacts              Contact[]
  journalEntries        JournalEntry[]
  householdRecords      Household[]
  
  // Link to Creator User
  createdById           String?
  createdBy             User?        @relation(fields: [createdById], references: [id])
}

model Contact {
  id                     String   @id @default(uuid())
  advisorId              String
  advisor                Advisor  @relation(fields: [advisorId], references: [id], onDelete: Cascade)
  contactType            String   // Advisor, Executive Assistant, Partner, Attorney, CPA, Compliance Contact, OSJ / Supervisory Contact, Custodian Contact, Operations Contact, Other
  name                   String
  title                  String?
  company                String?
  email                  String?
  phone                  String?
  mobilePhone            String?
  preferredContactMethod String   @default("Email") // Email, Phone, Text, Other
  roleInTransition       String?
  notes                  String?
  primaryContact         Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model Assessment {
  id                    String   @id @default(uuid())
  advisorId             String
  advisor               Advisor  @relation(fields: [advisorId], references: [id], onDelete: Cascade)
  
  notes                 String?  // Holds status, evidence notes, advisor profile data, etc.
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Client Data Readiness
  emailCompletenessPercent     Float    @default(0)
  phoneCompletenessPercent     Float    @default(0)
  addressCompletenessPercent   Float    @default(0)
  householdingQualityScore     Int      @default(1) // 1-10
  duplicateRecordRiskScore     Int      @default(1) // 1-10
  clientNotesQualityScore      Int      @default(1) // 1-10

  // KYC / Documentation Readiness
  kycUpdateFrequency           String   @default("Ad-hoc") // Annual, Triennial, Ad-hoc
  trustedContactCompletenessPercent Float @default(0)
  beneficiaryReviewStatus      String   @default("None") // Complete, Incomplete, None
  riskToleranceCurrentPercent  Float    @default(0)
  investmentObjectiveCurrentPercent Float @default(0)
  missingSignatureRiskScore    Int      @default(1) // 1-10
  documentStorageQualityScore  Int      @default(1) // 1-10

  // Transfer Complexity
  percentIraAccounts           Float    @default(0)
  percentTrustAccounts         Float    @default(0)
  percentEntityAccounts        Float    @default(0)
  percentAnnuityAltAccounts    Float    @default(0)
  directBusinessAmount         Float    @default(0)
  heldAwayAssetsNotes          String?
  transferComplexityScore      Int      @default(1) // 1-10

  // Operational Readiness
  staffCapacityScore           Int      @default(1) // 1-10
  crmExportQualityScore        Int      @default(1) // 1-10
  taskManagementScore          Int      @default(1) // 1-10
  digitalSignatureReadinessScore Int    @default(1) // 1-10
  communicationPlanScore       Int      @default(1) // 1-10

  // Compliance / Protocol Awareness
  employmentAgreementReviewed  Boolean  @default(false)
  nonSolicitNonCompeteConcerns Boolean  @default(false)
  legalReviewStatus            String   @default("None") // Completed, Pending, None
  complianceRiskNotes          String?

  // Generated Know Your Book™ Index Scores (calculated on save)
  overallReadinessScore        Float    @default(0)
  clientDataScore              Float    @default(0)
  kycDocumentationScore        Float    @default(0)
  transferComplexityScoreVal   Float    @default(0)
  operationalScore             Float    @default(0)
  complianceProtocolScore      Float    @default(0)
  communicationScore           Float    @default(0)
  
  // Link to Creator User
  createdByUserId              String?
  createdByUser                User?    @relation(fields: [createdByUserId], references: [id])
  findings                     Finding[]
}

model JournalEntry {
  id            String   @id @default(uuid())
  advisorId     String
  advisor       Advisor  @relation(fields: [advisorId], references: [id], onDelete: Cascade)
  title         String
  entryType     String   // Discovery Call, Meeting, Phone Call, Internal Note, Compliance, Operations, Transition Planning, Risk, Follow-up, General
  date          String   // e.g. YYYY-MM-DD
  author        String
  summary       String
  detailedNotes String?
  confidential  Boolean  @default(false)
  pinned        Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Finding {
  id             String     @id @default(uuid())
  assessmentId   String
  assessment     Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  category       String     // Client Records, KYC, Documentation, Operations, Compliance, Account Types, Technology, Communication, Other
  title          String
  description    String
  severity       String     // Critical, High, Moderate, Low
  impact         String?
  recommendation String?
  owner          String     // CTS, Advisor, Advisor Staff, Compliance, Legal, Unknown
  status         String     // Open, In Progress, Resolved, Not Applicable
  reviewerNotes  String?
  evidenceSummary String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  priority       String?    // Urgent, High, Normal, Low
  assignedTo     String?    // CTS Consultant, Advisor, etc.
  dueDate        DateTime?
  resolutionNotes String?

  householdId     String?
  household       Household? @relation(fields: [householdId], references: [id], onDelete: Cascade)
  accountId       String?
  account         Account?   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  checklistItemId String?
  checklistItem   AccountChecklistItem? @relation(fields: [checklistItemId], references: [id], onDelete: Cascade)
}

model Household {
  id                   String   @id @default(uuid())
  advisorId            String
  advisor              Advisor  @relation(fields: [advisorId], references: [id], onDelete: Cascade)
  name                 String   // Household Name
  primaryClientName    String
  secondaryClientName  String?
  totalAum             Float?   // In Millions USD or absolute
  revenue              Float?
  email                String?
  phone                String?
  address              String?
  assignedConsultant   String?  // Assigned CTS Consultant
  notes                String?
  readinessStatus      String   @default("Not Reviewed") // Ready, Minor Cleanup, Significant Cleanup, Not Ready, Not Reviewed
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  accounts             Account[]
  findings             Finding[]
}

model Account {
  id                   String   @id @default(uuid())
  householdId          String
  household            Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  name                 String   // Account Name
  type                 String   // Individual, Joint, Trust, IRA, Roth IRA, Inherited IRA, SEP IRA, SIMPLE IRA, 401(k), 529, Entity, Estate, Annuity, Alternative Investment, Direct Business, Other
  value                Float?   // Account Value
  custodian            String?
  registration         String?
  notes                String?
  readinessStatus      String   @default("Not Reviewed") // Ready, Missing Items, Needs Review, Not Ready, Not Reviewed
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  checklistItems       AccountChecklistItem[]
  findings             Finding[]
}

model AccountChecklistItem {
  id            String              @id @default(uuid())
  accountId     String
  account       Account             @relation(fields: [accountId], references: [id], onDelete: Cascade)
  itemKey       String // Unique key mapped to RequirementLibrary
  itemName      String // Copied from RequirementLibrary.name for convenience
  status        String              @default("Not Applicable") // Present, Missing, Needs Review, Not Applicable
  notes         String              @default("")
  verifiedBy    String              @default("")
  verifiedDate  String              @default("")
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  findings      Finding[]
  requirementId String?
  requirement   RequirementLibrary? @relation(fields: [requirementId], references: [id], onDelete: SetNull)

  @@unique([accountId, itemKey])
}

model DocumentType {
  id                  String               @id @default(uuid())
  name                String               @unique
  documentKey         String               @unique
  category            String
  description         String?
  typicalAccountTypes String               @default("All")
  critical            Boolean              @default(false)
  active              Boolean              @default(true)
  notes               String?
  displayOrder        Int                  @default(0)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  requirements        RequirementLibrary[]
}

model RequirementLibrary {
  id                    String               @id @default(uuid())
  name                  String
  description           String?
  category              String
  appliesToAccountTypes String // Comma-separated values, e.g., "IRA,Roth IRA" or "All"
  required              Boolean              @default(true)
  critical              Boolean              @default(false)
  weight                Float                @default(1.0)
  displayOrder          Int                  @default(0)
  active                Boolean              @default(true)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  documentTypes         DocumentType[]
  profileRequirements   ProfileRequirement[]
  checklistItems        AccountChecklistItem[]
}

model RequirementProfile {
  id                  String               @id @default(uuid())
  name                String               @unique
  description         String?
  active              Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  profileRequirements ProfileRequirement[]
}

model ProfileRequirement {
  id            String             @id @default(uuid())
  profileId     String
  profile       RequirementProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  requirementId String
  requirement   RequirementLibrary @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  state         String             @default("Required") // Required, Optional, Hidden
  overrideWeight Float?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@unique([profileId, requirementId])
}

model AccountType {
  id           String   @id @default(uuid())
  name         String   @unique
  description  String?
  active       Boolean  @default(true)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CrmMapping {
  id        String   @id @default(uuid())
  crmType   String   @unique // e.g., "Redtail", "Wealthbox", "Salesforce", etc.
  mapping   String   // Stringified JSON of column index/name mappings
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
